{
  "name": "protein-index",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "pnpm test:unit && pnpm test:worker",
    "test:unit": "vitest run",
    "test:worker": "vitest run --config vitest.worker.config.ts",
    "test:watch": "vitest",
    "cf-typegen": "wrangler types",
    "db:migrate": "wrangler d1 migrations apply protein-index --local",
    "data:stage": "tsx scripts/sync.ts stage",
    "data:seed": "tsx scripts/sync.ts seed",
    "data:coverage": "tsx scripts/sync.ts coverage",
    "data:publish": "tsx scripts/sync.ts publish",
    "check": "pnpm cf-typegen && pnpm typecheck && pnpm test && pnpm build",
    "release:startup": "wrangler deploy --dry-run --outfile .data/worker.bundle && wrangler check startup --worker .data/worker.bundle --outfile .data/worker-startup.cpuprofile",
    "release:dry-run": "wrangler deploy --dry-run --outdir .data/deploy-dry-run",
    "release:preflight": "pnpm check && pnpm release:startup && pnpm release:dry-run",
    "deploy": "bash ../fleet-ops/scripts/fleet-deploy-guard.sh protein-index && pnpm release:preflight && wrangler deploy --strict"
  },
  "dependencies": {
    "hono": "^4.12.30",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.45.0",
    "@cloudflare/vitest-pool-workers": "^0.18.5",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "lightningcss": "^1.32.0",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "wrangler": "^4.111.0"
  }
}
